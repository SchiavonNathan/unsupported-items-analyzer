# Copie este arquivo para .env e preencha com as suas credenciais.

# URL base do servidor Zabbix (obrigatório)
ZABBIX_URL=https://zabbix.empresa.com

# Autenticação por token (recomendado)
ZABBIX_TOKEN=

# OU autenticação por usuário/senha (usado somente se ZABBIX_TOKEN estiver vazio)
ZABBIX_USER=
ZABBIX_PASSWORD=

# Tempo em segundos para cache dos dados no modo --serve (padrão: 300)
CACHE_TTL=300

# Palavras-chave adicionais para detectar falhas de coleta, separadas por vírgula
# (padrão: nodata,no data,not supported,unsupported)
# COLLECTION_KEYWORDS=nodata,no data,not supported,unsupported
